# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Google Ads ───────────────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
# Refresh token from OAuth2 flow
GOOGLE_ADS_REFRESH_TOKEN=your_google_refresh_token
# Developer token from Google Ads API Center (https://ads.google.com/aw/apicenter)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
# Your Google Ads Manager Account (MCC) customer ID — digits only, no dashes
GOOGLE_ADS_CUSTOMER_ID=1234567890
# Login customer ID if using a manager account (same as CUSTOMER_ID for non-MCC)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# ─── Microsoft Advertising (Bing Ads) ─────────────────────────────────────────
# App registration at https://apps.microsoft.com/
MICROSOFT_ADS_CLIENT_ID=your_microsoft_client_id
MICROSOFT_ADS_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_ADS_REFRESH_TOKEN=your_microsoft_refresh_token
# Developer token from https://ads.microsoft.com/ > Tools > API Access
MICROSOFT_ADS_DEVELOPER_TOKEN=your_microsoft_developer_token
# Your Bing Ads Account ID and Customer ID
MICROSOFT_ADS_ACCOUNT_ID=12345678
MICROSOFT_ADS_CUSTOMER_ID=87654321

# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Private App access token from HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Custom HubSpot deal properties for UTM tracking (adjust to match your portal)
HUBSPOT_UTM_CAMPAIGN_PROP=utm_campaign
HUBSPOT_UTM_SOURCE_PROP=utm_source
HUBSPOT_UTM_MEDIUM_PROP=utm_medium
# HubSpot pipeline ID for the pipeline you want to track (leave blank to track all)
HUBSPOT_PIPELINE_ID=

# ─── Cache ────────────────────────────────────────────────────────────────────
# How long to cache API responses in seconds (default: 30 minutes)
CACHE_TTL_SECONDS=1800
